{
  "name": "@anthropic-claude-code/proxy",
  "version": "0.1.0",
  "description": "Claude Code HTTP proxy with provider routing and model mapping",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "vitest",
    "test:run": "vitest --run",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "bottleneck": "^2.19.5",
    "cors": "^2.8.6",
    "eventsource-parser": "^3.0.8",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "keytar": "^7.9.0",
    "on-finished": "^2.4.1",
    "p-retry": "^8.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/on-finished": "^2.3.5",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

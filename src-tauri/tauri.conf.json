{
  "$schema": "https://raw.githubusercontent.com/nicklasxyz/tauri2-schema/main/schema.json",
  "productName": "ClaudeCode Proxy",
  "version": "0.2.0",
  "identifier": "com.claudecode.proxy",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build && bash scripts/bundle-proxy.sh",
    "frontendDist": "../apps/web/out",
    "devUrl": "http://localhost:3457"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ClaudeCode Proxy",
        "label": "popup",
        "url": "/popup",
        "width": 350,
        "height": 460,
        "visible": false,
        "center": false,
        "resizable": false,
        "decorations": false,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.png"
    ],
    "resources": [
      "proxy-bundle/"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzNjA5QUU3RDEwNDg5MzIKUldReWlRVFI1NXBnSTQxSXY5cjdldk5pM2V2dFZRUndKVE5HaHR5aU1QQks3blhiMEl5MFVCREQK",
      "endpoints": [
        "https://github.com/feltrindavide/claude-code-proxy/releases/latest/download/latest.json"
      ]
    }
  }
}
